# Copy to .env and fill in before `sst deploy` (do not commit .env).
# See docs/infra-deploy.md

# SST app name — must match the deployed Pulumi stack name.
# Production uses "agent-task-bot" (the original deploy name).
# SST_APP_NAME=agent-task-bot

SST_API_DOMAIN=
SST_DNS_ZONE_ID=
SST_ACM_CERT_ARN=
SST_UI_ORIGIN=
SST_EC2_HEALTH_URL=
# Optional:
# SST_DIGEST_UI_URL=
# SST_GITHUB_OWNER=
# DYNAMO_TABLE_NAME=agent-tasks
# KNOWN_REPOS=
# SST_SCAN_REPOS=
