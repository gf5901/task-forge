# Discord bot token — get from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Channel ID where task status-change notifications are sent
NOTIFICATION_CHANNEL_ID=

# DynamoDB table for task storage
DYNAMO_TABLE=agent-tasks
# AWS_REGION=us-west-2

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# --- Task Runner / Poller ---

# Polling interval in seconds (default: 15). The poller checks DynamoDB for
# pending tasks and reply-pending comments every N seconds and spawns runners.
POLL_INTERVAL=15

# Max concurrent agent processes (default: 2). Each uses a numbered slot lock.
MAX_CONCURRENT_RUNNERS=2

# Path to Cursor agent CLI binary
AGENT_BIN=agent

# Working directory where the agent executes tasks
WORK_DIR=/home/ec2-user

# Timeout per task in seconds (default: 900 = 15 min)
TASK_TIMEOUT=900

# --- Compound Pipeline ---

# Auto-run a doc-update agent step after each task (true/false)
AUTO_DOCS=true

# Auto-create a PR for agent changes (true/false, requires gh CLI)
AUTO_PR=true

# Auto-decompose tasks into subtasks via planning pass (true/false)
AUTO_PLAN=true

# Path to GitHub CLI binary
GH_BIN=gh

# Planning pass timeout in seconds (default: 120)
PLAN_TIMEOUT=120

# --- Model Routing ---
# Planning & final review use MODEL_FULL (expensive, high-reasoning).
# Execution, docs, PR body, self-review use MODEL_FAST (cheap, code-focused).
# MODEL_DEFAULT is available as a middle tier for tasks that need more reasoning.
# If a model is unavailable at runtime, the agent CLI retries with its default.

# Model for execution, docs, PR body, self-review
MODEL_FAST=composer-2

# Middle-tier model (leave empty to use CLI default)
MODEL_DEFAULT=claude-4.6-sonnet-medium

# Model for planning, PR final review, daily cycle
MODEL_FULL=claude-4.6-opus-high-thinking

# --- Web UI ---

# Comma-separated allowed browser origins for CORS (FastAPI). In production, set to your SPA URL(s), e.g.
# CORS_ORIGINS=https://your-spa.example.com
# Host and port for the web UI (run via run_web.py)
WEB_HOST=0.0.0.0
WEB_PORT=8080

# --- Authentication ---

# Email and password for web UI login. If both are set, all routes require auth.
# Leave blank to disable authentication (open access).
AUTH_EMAIL=
AUTH_PASSWORD=

# Secret key for signing session cookies (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# If not set, a random key is generated at startup (sessions won't survive restarts).
AUTH_SECRET_KEY=

# Session cookies: Secure flag (default true). Set false for plain HTTP / local dev.
HTTPS_ONLY=true

# --- GitHub Webhook (auto-deploy on merge to main) ---

# Secret for verifying GitHub webhook payloads (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# Must match the secret configured in GitHub repo → Settings → Webhooks
GITHUB_WEBHOOK_SECRET=

# --- Security ---

# Daily budget cap in USD for agent execution costs (default: 0 = unlimited)
# Estimated from token usage. When exceeded, new task dispatch is blocked until midnight UTC.
BUDGET_DAILY_USD=0

# Discord role name required for mutating bot commands (create, delete, status, sync).
# Leave blank to allow all server members. Read-only commands (list, view) are unrestricted.
DISCORD_ADMIN_ROLE=

# --- Discord Webhook (deploy alerts) ---

# Webhook URL for deploy failure alerts posted to Discord.
# Create at: Discord → Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# --- Remote SSH ---

# SSH destination for scripts/remote-pull.sh (e.g. ec2-user@your-host.example.com)
EC2_SSH_HOST=

# Clone path on the EC2 host (default below). Override if you use a different layout.
# EC2_REPO_DIR=/home/ec2-user/workspace/task-forge
# Optional: clone path for disk-cleanup cron (defaults below)
# TASK_FORGE_REPO=/home/ec2-user/workspace/task-forge
